# ============================================
# SECRETS FILE TEMPLATE
# ============================================
# Copy this file to .env.secrets and fill in your values
# NEVER commit .env.secrets to git!
# ============================================

# Application
# Generate with: php artisan key:generate
APP_KEY=base64:your-generated-app-key-here=

# Database (PostgreSQL)
# Use strong password: min 32 chars, mix of upper/lower/numbers/symbols
POSTGRES_PASSWORD=change_this_secure_password_here!
DB_PASSWORD=change_this_secure_password_here!

# Sanctum (for cookie-based auth)
# List your domains (comma-separated)
SANCTUM_STATEFUL_DOMAINS=localhost,127.0.0.1


